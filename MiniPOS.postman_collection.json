				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.data && response.data.accessToken) {",
									"    pm.collectionVariables.set(\"accessToken\", response.data.accessToken);",
									"    console.log(\"Access Token saved.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
